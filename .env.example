# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=admin_api

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenTelemetry
OTEL_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=admin-api

# Prometheus Metrics
METRICS_PORT=9090
